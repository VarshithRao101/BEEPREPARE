rules_version = '2';

// BEEPREPARE Security Rules for Firebase Storage
// NOTE: Firebase Admin SDK (used in our backend) bypasses these rules automatically.
// These rules only apply to Firebase Client SDK connections.

service firebase.storage {
  match /b/{bucket}/o {
    
    // Teacher Notes & Syllabus Content
    match /notes/{teacherId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == teacherId;
    }
    
    // User Feedback & Support Attachments
    match /feedback_attachments/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User Profile Images
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true; // Public profiles
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
