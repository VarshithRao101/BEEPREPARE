// ═══════════════════════════════════════════════════════════════════
// BEEPREPARE — FIRESTORE SECURITY RULES v2.0
// ═══════════════════════════════════════════════════════════════════
// Deploy with: firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────

    // Is the request from a signed-in Firebase user?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Is the requester the same user as the document owner?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Is the user email verified?
    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Does the incoming data only contain the allowed keys?
    function onlyAllowedKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    // Is the field being changed from its current value?
    function fieldUnchanged(field) {
      return resource.data[field] == request.resource.data[field];
    }

    // Is the value a non-empty string within max length?
    function validString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    // Is the value a valid non-negative integer?
    function validInt(val, min, max) {
      return val is int && val >= min && val <= max;
    }

    // Rate limiting helper: allow only if last write was > N seconds ago
    function notRateLimited(field, windowSecs) {
      return !('lastWrite' in resource.data) ||
             request.time > resource.data[field].toMillis() + duration.value(windowSecs, 's');
    }

    // ── /users/{userId} ───────────────────────────────────────────
    match /users/{userId} {

      // READ: only the user themselves
      allow read: if isOwner(userId);

      // CREATE: only authenticated, email-verified users creating their own doc
      allow create: if isOwner(userId)
        && isEmailVerified()
        && onlyAllowedKeys([
          'googleUid', 'name', 'email', 'profilePic', 'college',
          'role', 'isActivated', 'activatedAt', 'createdAt',
          'studyCircles', 'extraSlots', 'lastLoginAt', 'preferences'
        ])
        && request.resource.data.role == 'student'      // No self-promoted admins
        && request.resource.data.isActivated == false   // Not self-activated
        && request.resource.data.googleUid == userId;

      // UPDATE: limited self-update — cannot change critical fields
      allow update: if isOwner(userId)
        && isEmailVerified()
        && fieldUnchanged('role')
        && fieldUnchanged('isActivated')
        && fieldUnchanged('googleUid')
        && fieldUnchanged('email')
        && fieldUnchanged('extraSlots')
        && fieldUnchanged('activatedAt')
        && onlyAllowedKeys([
          'name', 'profilePic', 'college', 'preferences',
          'lastLoginAt',
          // Keep existing server fields unchanged
          'googleUid', 'email', 'role', 'isActivated',
          'activatedAt', 'createdAt', 'studyCircles', 'extraSlots'
        ]);

      // DELETE: never allowed from client
      allow delete: if false;
    }

    // ── /payments/{paymentId} ─────────────────────────────────────
    match /payments/{paymentId} {

      // READ: only the owning user (matched via userId field)
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // CREATE: backend only (no client writes)
      allow create: if false;

      // UPDATE: backend only
      allow update: if false;

      // DELETE: backend only
      allow delete: if false;
    }

    // ── /studycircles/{circleId} ──────────────────────────────────
    match /studycircles/{circleId} {

      // READ: authenticated members only
      allow read: if isAuthenticated()
        && (resource.data.members.hasAny([request.auth.uid])
            || resource.data.leaderId == request.auth.uid);

      // CREATE: authenticated, email-verified students
      allow create: if isAuthenticated()
        && isEmailVerified()
        && request.resource.data.leaderId == request.auth.uid
        && request.resource.data.members.size() == 1
        && validString(request.resource.data.name, 100)
        && request.resource.data.memberCount == 1;

      // UPDATE: leader can update name/description; members can join/leave
      allow update: if isAuthenticated()
        && (
          // Leader updates metadata
          (resource.data.leaderId == request.auth.uid
            && fieldUnchanged('leaderId')
            && fieldUnchanged('createdAt'))
          ||
          // Member join (adds themselves)
          (request.resource.data.members.hasAll(resource.data.members)
            && request.resource.data.members.hasAny([request.auth.uid])
            && request.resource.data.memberCount == resource.data.memberCount + 1)
          ||
          // Member leave (removes themselves)
          (resource.data.members.hasAny([request.auth.uid])
            && !request.resource.data.members.hasAny([request.auth.uid])
            && request.resource.data.memberCount == resource.data.memberCount - 1)
        );

      // DELETE: leader only
      allow delete: if isAuthenticated()
        && resource.data.leaderId == request.auth.uid;

      // Sub-collection: messages
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/studycircles/$(circleId)).data.members.hasAny([request.auth.uid]);

        allow create: if isAuthenticated()
          && isEmailVerified()
          && request.resource.data.senderId == request.auth.uid
          && validString(request.resource.data.content, 2000)
          && get(/databases/$(database)/documents/studycircles/$(circleId)).data.members.hasAny([request.auth.uid]);

        allow update: if false;  // No editing messages
        allow delete: if false;  // No deleting messages from client
      }
    }

    // ── /quotes/{quoteId} ────────────────────────────────────────
    match /quotes/{quoteId} {
      // Public read (quotes are public content)
      allow read: if true;
      // Write: backend only
      allow write: if false;
    }

    // ── /announcements/{announcementId} ──────────────────────────
    match /announcements/{announcementId} {
      // Authenticated read only
      allow read: if isAuthenticated();
      // Write: backend only
      allow write: if false;
    }

    // ── /feedback/{feedbackId} ────────────────────────────────────
    match /feedback/{feedbackId} {
      // Read: only own feedback
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Create: authenticated, email-verified, one per user (enforced in backend)
      allow create: if isAuthenticated()
        && isEmailVerified()
        && request.resource.data.userId == request.auth.uid
        && validString(request.resource.data.content, 2000)
        && onlyAllowedKeys(['userId', 'content', 'createdAt', 'rating', 'category']);

      // No updates or deletes from client
      allow update: if false;
      allow delete: if false;
    }

    // ── /licenseKeys/{keyId} ──────────────────────────────────────
    match /licenseKeys/{keyId} {
      // No client access whatsoever — backend only
      allow read, write: if false;
    }

    // ── /adminLogs/{logId} ────────────────────────────────────────
    match /adminLogs/{logId} {
      // No client access — backend only
      allow read, write: if false;
    }

    // ── /systemConfig/{configId} ─────────────────────────────────
    match /systemConfig/{configId} {
      // No client access — backend only
      allow read, write: if false;
    }

    // ── /banks/{bankId} ───────────────────────────────────────────
    match /banks/{bankId} {
      // Authenticated read (users need to see payment QR/UPI)
      allow read: if isAuthenticated();
      // Write: backend only
      allow write: if false;
    }

    // ── DEFAULT: Deny everything else ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
