rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for safety
    function isAuthenticated() {
      return request.auth != null;
    }

    // AUTH_LOGS: Only allow creation, no reads or deletes
    match /login_logs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ACTIVATION_KEYS: Backend access only via Admin SDK
    // But we add rules here as a second layer of defense
    match /activation_keys/{keyId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() 
        && resource.data.isUsed == false 
        && request.resource.data.isUsed == true;
      allow create, delete: if false;
    }

    // REDEEM_KEYS: Same as above
    match /redeem_keys/{keyId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() 
        && resource.data.is_used == false 
        && request.resource.data.is_used == true;
      allow create, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
